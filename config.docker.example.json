    "enabled": false,
    "bot_token": "",
    "chat_id": ""
  },
  "windows_toast": {
    "enabled": false
  },
  "parsing": {
    "download_regex": "",
    "upload_regex": ""
  },
  "server_refresh_alert_enabled": false,
  "increment_alert_gib": 0.0
